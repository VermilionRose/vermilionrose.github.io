---
// Contact
---

<section id="contact">
  <div class="container">
    <p class="section-label">Contact</p>
    <h2>Let's work together</h2>
    <p class="contact-sub">
      Booking inquiries, show questions, or just want to talk production &mdash;
      reach out directly.
    </p>

    <div class="contact-grid">
      <button class="card contact-card" data-copy="contact@vermilionrose.me">
        <span class="contact-icon">✉</span>
        <div>
          <p class="contact-label">Email</p>
          <p class="contact-value">contact@vermilionrose.me</p>
        </div>
      </button>

      <button class="card contact-card" data-copy="+19175260455">
        <span class="contact-icon">📞</span>
        <div>
          <p class="contact-label">Phone</p>
          <p class="contact-value">+1 917 526 0455</p>
        </div>
      </button>

      <a href="https://github.com/vermilionrose" target="_blank" rel="noopener" class="card contact-card">
        <span class="contact-icon">⌨</span>
        <div>
          <p class="contact-label">GitHub</p>
          <p class="contact-value">vermilionrose</p>
        </div>
      </a>
    </div>

    <p class="copy-hint">Tap email or phone to copy</p>

    <!-- Testimonials placeholder — to be added once collected -->
    <!--
    <div class="testimonials">
      <h3>What people say</h3>
      ...
    </div>
    -->
  </div>
</section>

<style>
  h2 { margin-bottom: 0.5rem; }

  .contact-sub {
    color: var(--text-muted);
    margin-bottom: 2.5rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  @media (max-width: 600px) {
    .contact-grid { grid-template-columns: 1fr; }
  }

  .contact-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    text-decoration: none;
    color: var(--text);
    transition: background 0.2s, border-color 0.2s;
    /* reset button styles */
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.75rem 2rem;
    font-family: inherit;
    font-size: inherit;
    text-align: left;
    cursor: pointer;
    width: 100%;
  }

  .contact-card:hover {
    border-color: var(--accent);
    color: var(--text);
  }

  .contact-card.copied {
    border-color: var(--sage);
  }

  .contact-card.copied .contact-value {
    color: var(--sage);
  }

  .copy-hint {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 0.75rem;
    opacity: 0.6;
    max-width: none;
  }

  .contact-icon {
    font-size: 1.4rem;
    flex-shrink: 0;
  }

  .contact-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent-alt);
    margin-bottom: 0.15rem;
    max-width: none;
  }

  .contact-value {
    font-size: 0.95rem;
    color: var(--blush);
    max-width: none;
    overflow-wrap: break-word;
    transition: color 0.2s;
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy!;
      await navigator.clipboard.writeText(text);

      const val = btn.querySelector('.contact-value')!;
      const original = val.textContent;
      val.textContent = 'Copied!';
      btn.classList.add('copied');

      setTimeout(() => {
        val.textContent = original;
        btn.classList.remove('copied');
      }, 2000);
    });
  });
</script>
