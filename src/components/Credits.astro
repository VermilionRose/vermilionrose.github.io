  { event: "International Battle of the Badges", client: "FDNY Bravest", via: "Flypack NY", role: "Encoding Engineer", year: "Mar 2026" },
  // 2025
  { event: "Unstoppable Africa 2025", client: "UN", via: "Live Star Entertainment", role: "Encoding Engineer", year: "Sep 2025" },
  { event: "Essencefest", client: "Solomon Group", via: "Flypack NY", role: "Encoding Engineer", year: "Jul 2025" },
  { event: "Nike SNKRS Showcase", client: "Nike", via: "WAVDWGS", role: "vMix Operator", year: "Jul 2025" },
  { event: "Call of Duty Next 2025", client: "Activision", via: "OS Studios", role: "Team Lead", year: "2025" },
  { event: "Critical Role — Mighty Nein Wedding (Radio City Music Hall)", client: "Critical Role", via: "Flypack NY", role: "GFX Operator", year: "2025" },
  { event: "Alienware Artifact Challenge", client: "Alienware / Twitch", via: "OS Studios", role: "vMix Operator", year: "2025" },
  { event: "AT&T Playoff Fan Central", client: "AT&T", via: "OS Studios", role: "Gameplay Director", year: "2025" },
  { event: "St. Patrick's Day Parade — Dublin, Ireland", client: "Live Star Entertainment", role: "Encoding Engineer", year: "Mar 2025" },
  { event: "Corporate & Pharma Shows — Inception Studios NJ", client: "Various", via: "Flypack NY", role: "Technical Director", year: "2024–ongoing" },
  { event: "Corporate Shows — Convene NYC", client: "Various", via: "Flypack NY", role: "vMix Operator", year: "2024–ongoing" },
  // 2024
  { event: "Neil Diamond — Chase Private Client / Backstage on Broadway", client: "Chase", via: "Trigger Finger Productions", role: "Encoding Engineer", year: "Dec 10 2024" },
  { event: "LivePartyLAN D&D", client: "LivePartyLAN", via: "Will Abreu", role: "Associate Producer / vMix Operator", year: "Jul 2023–Oct 2024" },
  { event: "Copa de la Familia Qualifiers", client: "Duracell", via: "OS Studios", role: "vMix Operator", year: "2024" },
  { event: "Should the US Still Police the World", client: "The Free Press", role: "vMix Operator", year: "2024" },
  { event: "Salesforce Agentforce 2.0", client: "Salesforce", via: "Super Tempo Productions", role: "Remote vMix Operator (vMix on AWS)", year: "2024" },
  { event: "Valorant Block Party", client: "Riot Games", via: "OS Studios", role: "Game Administrator", year: "Jul 21 2024" },
  { event: "Yu-Gi-Oh World Champions 2024", client: "Konami", via: "OS Studios", role: "vMix Operator — main stream; devised dual-language graphics method (single switcher)", year: "2024" },
  { event: "Play One Up", client: "Play One Up", role: "GFX Operator", year: "Apr 2024" },
  { event: "NBA2KL Season", client: "NBA 2K League", via: "OS Studios", role: "Encoding Engineer", year: "Feb–Jun 2024" },
  { event: "NBA2K24 Launch", client: "2K Sports", via: "OS Studios", role: "Encoding Engineer", year: "2024" },
  { event: "NIKE SNKRS Heating Up Talkshow Series", client: "Nike", via: "WAVDWGS", role: "vMix Operator", year: "2024" },
  { event: "AT&T Roadshow", client: "AT&T", via: "OS Studios", role: "vMix Operator", year: "2024" },
  { event: "Satellite Media Tours", client: "Various", role: "Encoding Engineer", year: "2024–ongoing" },
  { event: "CBLOL UE — Unofficial English Broadcast", client: "Riot Games", role: "Producer / vMix Operator / On-call Engineer", year: "2022–ongoing", note: "CBLOL UE — first English-language CBLOL broadcast. Production quality led Riot to launch their own official English broadcast (Spring 2025 split) staffed by CBLOL UE casters; volunteer broadcast continues with co-stream rights." },
  // 2023
  { event: "NACL Qualifiers", client: "Riot Games", via: "Loadscreen", role: "Broadcast Engineer", year: "Sep 2023" },
  { event: "Annihilator Cup", client: "AT&T", via: "OS Studios", role: "Game Observer", year: "Summer 2023" },
  { event: "Pittsburgh Knight's Gauntlets", client: "Riot Games", via: "Pittsburgh Knights", role: "vMix Operator", year: "2021–2023" },
  { event: "NA Dota Championship League (NADCL)", client: "Pdager Entertainment", role: "vMix Operator", year: "Sep 2023" },
  // 2022
  { event: "Axie Con", client: "Sky Mavis", via: "Community Gaming", role: "Broadcast Engineer / vMix Operator", year: "Late 2022" },
  { event: "Bornless Broadcast", client: "The Bornless", role: "vMix Operator", year: "Oct 2022" },
  // Earlier
  { event: "Great Lakes Gaming", client: "Great Lakes Gaming", role: "Operator", year: "2019" },
];
---

<section id="credits">
  <div class="container">
    <p class="section-label">Credits</p>
    <h2>Event logbook</h2>
    <p class="credits-note">
      Selected shows since 2019 — esports, corporate, broadcast, and live events.
    </p>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Event</th>
            <th>Client</th>
            <th>Role</th>
            <th>Year</th>
          </tr>
        </thead>
        <tbody>
          {credits.map((c) => (
            <tr>
              <td>
                {c.event}
                {c.note && <span class="credit-note">{c.note}</span>}
              </td>
              <td>
                {c.client}
                {c.via && <span class="credit-via">via {c.via}</span>}
              </td>
              <td>{c.role}</td>
              <td>{c.year}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  h2 { margin-bottom: 0.5rem; }

  .credits-note {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
  }

  .table-wrap {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0 1rem;
  }

  .credit-via {
    display: block;
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 0.15rem;
  }

  .credit-note {
    display: block;
    font-size: 0.75rem;
    color: var(--text-muted);
    font-style: italic;
    margin-top: 0.2rem;
  }
</style>
