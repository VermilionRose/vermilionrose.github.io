---

<section id="gallery">
  <div class="container">
    <p class="section-label">Gallery</p>
    <h2>On the desk and in the room</h2>

    <div class="gallery-grid">
      {visiblePhotos.map((p) => (
        <figure class="gallery-item">
          <img
            src={`/images/${p.file}`}
            alt={p.caption}
            width={dims[p.file]?.[0]}
            height={dims[p.file]?.[1]}
            loading="lazy"
          />
          <figcaption>
            <span class="caption-text">{p.caption}</span>
            {p.role !== "—" && <span class="pill">{p.role}</span>}
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  h2 { margin-bottom: 2rem; }

  .gallery-grid {
    columns: 4;
    column-gap: 0.5rem;
  }

  .gallery-item {
    break-inside: avoid;
    margin-bottom: 0.5rem;
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--bg-card);
    border: 1px solid var(--border);
    position: relative;
    cursor: default;
  }

  .gallery-item img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.3s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.03);
  }

  figcaption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5rem 0.75rem 0.6rem;
    background: linear-gradient(to top, rgba(0,0,0,0.72) 0%, transparent 100%);
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 0.4rem;
    flex-wrap: wrap;
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .gallery-item:hover figcaption {
    opacity: 1;
  }

  .caption-text {
    font-size: 0.75rem;
    color: #fff;
    line-height: 1.3;
  }

  .pill {
    font-size: 0.65rem;
    flex-shrink: 0;
  }

  /* Mobile: show captions statically below, drop to fewer columns */
  @media (max-width: 900px) {
    .gallery-grid { columns: 3; }
  }

  @media (max-width: 600px) {
    .gallery-grid {
      columns: 2;
      column-gap: 0.4rem;
    }

    figcaption {
      position: static;
      background: none;
      opacity: 1;
      padding: 0.4rem 0.5rem;
    }

    .caption-text { color: var(--text-muted); }
  }
</style>
