---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'vMix Operator & Broadcast Engineer in NYC | Rose Media Group',
  description = 'vMix operator, graphics integrator, and engineer in charge. NYC-based live production freelancer.',
} = Astro.props;

const canonicalURL = 'https://vermilionrose.me';
const trellisURL = 'https://trellis.vermilionrose.me';
const logoImage = `${canonicalURL}/images/rose_logo_white.png`;
const ogImage = `${canonicalURL}/images/og_image.png`; // 1200x630 share card (logo on brand background)

// Structured data (JSON-LD) — linked graph so search engines read Rose (Person),
// Rose Media Group (ProfessionalService), and the site as one connected entity.
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': `${canonicalURL}/#rose`,
      name: 'Rose',
      jobTitle: ['vMix Operator', 'Broadcast Engineer', 'Graphics Integrator'],
      url: canonicalURL,
      image: logoImage,
      email: 'contact@vermilionrose.me',
      telephone: '+1-917-526-0455',
      worksFor: { '@id': `${canonicalURL}/#rmg` },
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'New York',
        addressRegion: 'NY',
        addressCountry: 'US',
      },
      sameAs: [
        'https://github.com/vermilionrose',
        'https://www.linkedin.com/in/vermilionrose-jacobpochron',
      ],
      owns: [
        { '@id': `${trellisURL}/#trellis` },
        { '@id': `${trellisURL}/liana/ui/#liana` },
        { '@id': `${trellisURL}/spica/ui/#spica` },
      ],
    },
    {
      '@type': 'ProfessionalService',
      '@id': `${canonicalURL}/#rmg`,
      name: 'Rose Media Group',
      url: canonicalURL,
      image: logoImage,
      description:
        'Freelance live production and broadcast engineering: vMix operation, custom graphics integration, engineer-in-charge, and data-driven broadcast tooling. New York City based; available regionally and remote.',
      founder: { '@id': `${canonicalURL}/#rose` },
      email: 'contact@vermilionrose.me',
      telephone: '+1-917-526-0455',
      knowsAbout: [
        'vMix',
        'Live broadcast production',
        'Esports broadcast',
        'Graphics integration',
        'Engineer in charge',
        'Data engineering for live graphics',
      ],
      areaServed: [
        { '@type': 'City', name: 'New York City' },
        { '@type': 'City', name: 'Washington, D.C.' },
        { '@type': 'City', name: 'Boston' },
      ],
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'New York',
        addressRegion: 'NY',
        addressCountry: 'US',
      },
    },
    {
      '@type': 'WebSite',
      '@id': `${canonicalURL}/#website`,
      url: canonicalURL,
      name: 'Rose Media Group',
      publisher: { '@id': `${canonicalURL}/#rmg` },
    },
    {
      '@type': 'WebApplication',
      '@id': `${trellisURL}/#trellis`,
      name: 'Trellis',
      url: trellisURL,
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web',
      description:
        'Multi-tenant broadcast platform: one API, one identity, shared auth and multi-tenancy — the foundation LIANA and SPICA run on.',
      creator: { '@id': `${canonicalURL}/#rose` },
      provider: { '@id': `${canonicalURL}/#rmg` },
    },
    {
      '@type': 'WebApplication',
      '@id': `${trellisURL}/liana/ui/#liana`,
      name: 'LIANA',
      url: `${trellisURL}/liana/ui/`,
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web',
      description:
        'Multi-tenant broadcast data CMS: rosters, schedules, brackets, and head-to-heads editable through a web UI and piped straight into vMix as live data sources. Runs on Trellis.',
      creator: { '@id': `${canonicalURL}/#rose` },
      provider: { '@id': `${canonicalURL}/#rmg` },
      isPartOf: { '@id': `${trellisURL}/#trellis` },
    },
    {
      '@type': 'WebApplication',
      '@id': `${trellisURL}/spica/ui/#spica`,
      name: 'SPICA',
      url: `${trellisURL}/spica/ui/`,
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web',
      description:
        'Broadcast rundowns and show timing: run-of-show blocks with cascading segment timing, a live operator panel, and call sheets. Runs on Trellis.',
      creator: { '@id': `${canonicalURL}/#rose` },
      provider: { '@id': `${canonicalURL}/#rmg` },
      isPartOf: { '@id': `${trellisURL}/#trellis` },
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/png" href="/images/rose_logo_white.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Rose Media Group" />
    <meta property="og:site_name" content="Rose Media Group" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured data (JSON-LD) -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <nav>
      <div class="nav-inner">
        <img src="/images/rose_logo_white.png" alt="Rose Media Group" class="nav-logo" />
        <ul class="nav-links">
          <li><a href="#about">About</a></li>
          <li><a href="#services">Services</a></li>
          <li><a href="#products">Products</a></li>
          <li><a href="#credits">Credits</a></li>
          <li><a href="#gallery">Gallery</a></li>
          <li><a href="#gear">Gear</a></li>
          <li><a href="#undergrowth">The Undergrowth</a></li>
          <li><a href="#contact">Contact</a></li>
        </ul>
      </div>
    </nav>

    <slot />

    <footer>
      <div class="container">
        <p>
          &copy; {new Date().getFullYear()} Rose Media Group &middot;
          <a href="mailto:contact@vermilionrose.me">contact@vermilionrose.me</a>
        </p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  footer {
    padding: 2rem 1.5rem;
    border-top: 1px solid var(--border);
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  footer a { color: var(--text-muted); }
  footer a:hover { color: var(--blush); }
</style>
